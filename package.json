{
  "name": "crystal-menu-ui",
  "version": "0.1.1",
  "description": "Unofficial Final Fantasy VII Remake-inspired JRPG glass HUD UI kit for React + TypeScript — 30 components (Equipment Screen, Materia, Weapon Matrix, Limit Gauge, Damage Numbers, Chapter Cards, etc.) with Optima typography, AI-ready docs, and bilingual EN/中文 documentation. 最终幻想 VII Remake 风格 JRPG 玻璃 HUD 组件库。",
  "author": "zq52xy",
  "homepage": "https://zq52xy.github.io/crystal-menu-ui/",
  "packageManager": "npm@11.6.2",
  "engines": {
    "node": ">=20.19.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zq52xy/crystal-menu-ui.git"
  },
  "bugs": {
    "url": "https://github.com/zq52xy/crystal-menu-ui/issues"
  },
  "type": "module",
  "main": "dist/cjs/index.cjs",
  "module": "dist/es/index.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/es/index.js",
      "require": "./dist/cjs/index.cjs"
    },
    "./style": "./dist/index.css",
    "./dist/index.css": "./dist/index.css"
  },
  "files": [
    "dist",
    "AI_USAGE.md",
    "README.md",
    "PROMPT.md",
    "DESIGN_PROMPT.md",
    "docs/ai-workflow.md",
    "docs/ai-user-guide.md",
    "docs/content",
    "docs/tokens.md",
    "skill/SKILL.md"
  ],
  "sideEffects": [
    "**/*.css",
    "**/*.less"
  ],
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build && tsc --project tsconfig.build.json --emitDeclarationOnly",
    "build:demo": "node scripts/build-demo-public.mjs",
    "prepublishOnly": "npm run build",
    "deploy": "npm run build:demo && gh-pages -d demo-dist",
    "art:readme": "node scripts/generate-readme-art.mjs",
    "typecheck": "tsc --noEmit",
    "smoke:package": "node scripts/package-smoke.mjs",
    "visual:smoke": "node scripts/visual-smoke.mjs",
    "audit:docs": "node scripts/audit-docs-coverage.mjs",
    "art:motion": "node scripts/generate-motion-showcase.mjs"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "classnames": "^2.5.1"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^5.1.1",
    "gh-pages": "^6.3.0",
    "gifenc": "^1.0.3",
    "less": "^4.4.2",
    "playwright": "^1.60.0",
    "pngjs": "^7.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.9.3",
    "vite": "^7.2.6"
  },
  "keywords": [
    "react",
    "react-components",
    "component-library",
    "design-system",
    "game-ui",
    "jrpg",
    "jrpg-ui",
    "jrpg-menu",
    "jrpg-hud",
    "rpg-ui",
    "fantasy-ui",
